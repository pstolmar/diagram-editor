{
  "definitions": [
    {
      "title": "Scroll Reveal",
      "id": "scroll-reveal",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block",
            "template": {
              "name": "Scroll Reveal",
              "model": "scroll-reveal"
            }
          }
        }
      }
    }
  ],
  "models": [
    {
      "id": "scroll-reveal",
      "fields": [
        {
          "component": "section",
          "name": "panels",
          "label": "Panels",
          "description": "Add reveal panels that trigger on scroll. Each panel row contains label, heading, body, and visual elements.",
          "required": true,
          "fields": [
            {
              "component": "text",
              "name": "label",
              "label": "Label",
              "description": "Optional small text above the heading (e.g., 'Step 1')",
              "required": false
            },
            {
              "component": "text",
              "name": "heading",
              "label": "Heading",
              "description": "Main heading text for this panel",
              "required": true
            },
            {
              "component": "richtext",
              "name": "body",
              "label": "Body",
              "description": "Description text or content for this panel",
              "required": false
            },
            {
              "component": "image",
              "name": "image",
              "label": "Visual / Image",
              "description": "Image, illustration, or visual element for this panel",
              "required": false
            }
          ]
        },
        {
          "component": "select",
          "name": "reveal-direction",
          "label": "Reveal Direction",
          "description": "Direction from which content reveals on scroll",
          "default": "fade",
          "required": false,
          "options": [
            {
              "value": "fade",
              "label": "Fade In"
            },
            {
              "value": "slide-left",
              "label": "Slide from Left"
            },
            {
              "value": "slide-right",
              "label": "Slide from Right"
            },
            {
              "value": "slide-up",
              "label": "Slide from Bottom"
            }
          ]
        },
        {
          "component": "select",
          "name": "reveal-timing",
          "label": "Reveal Timing",
          "description": "When panels reveal relative to scroll position",
          "default": "default",
          "required": false,
          "options": [
            {
              "value": "default",
              "label": "Default (50% in viewport)"
            },
            {
              "value": "early",
              "label": "Early (80% in viewport)"
            },
            {
              "value": "late",
              "label": "Late (20% in viewport)"
            }
          ]
        },
        {
          "component": "number",
          "name": "stagger-delay",
          "label": "Stagger Delay (ms)",
          "description": "Delay between each panel reveal (0 for no stagger)",
          "default": 100,
          "required": false
        }
      ]
    }
  ],
  "filters": []
}