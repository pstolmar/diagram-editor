#!/usr/bin/env bash
# tokenmiser — reads PLAN.md + markers, dispatches to claude -p
# Called by `t` when present in the repo root.
# Usage: ./tokenmiser "[PATCH] [MISER=N] [LINEAR] [REACTIVE] [DEPLOY] [VALIDATE=cmd] [YOLO] optional task override"
set -euo pipefail

MARKERS="${1:-}"

# ── Terminal status commands ─────────────────────────────────────────────────
RUNS_FILE=".tokenmiser/runs.json"

_tm_relative_time() {
  local ts="$1"
  local now
  now=$(date +%s)
  local then
  then=$(date -j -f "%Y-%m-%dT%H:%M:%S" "${ts%%.*}" +%s 2>/dev/null \
    || date -d "$ts" +%s 2>/dev/null || echo "$now")
  local diff=$(( now - then ))
  if   [ "$diff" -lt 120 ];   then echo "just now"
  elif [ "$diff" -lt 3600 ];  then echo "$(( diff / 60 )) min ago"
  elif [ "$diff" -lt 86400 ]; then echo "$(( diff / 3600 )) hr ago"
  elif [ "$diff" -lt 172800 ]; then echo "yesterday"
  else echo "$(( diff / 86400 )) days ago"
  fi
}

_tm_infer_model() {
  local miser="${1:-0}"
  if [ "$miser" -ge 8 ]; then echo "haiku"; elif [ "$miser" -ge 1 ]; then echo "sonnet"; else echo "sonnet"; fi
}

_tm_opus_est() {
  # Estimate Opus 4 cost: 5× actual cost (conservative fallback)
  local cost="${1:-0}"
  awk "BEGIN { printf \"%.4f\", $cost * 5 }"
}

_tm_savings_pct() {
  local actual="$1" opus="$2"
  awk "BEGIN { if ($opus > 0) printf \"%d\", ($opus - $actual) / $opus * 100; else print \"0\" }"
}

if [ "${MARKERS:-}" = "--status" ]; then
  if [ ! -f "$RUNS_FILE" ]; then
    echo "No runs found (${RUNS_FILE} missing)."
    exit 0
  fi
  LAST=$(tail -1 "$RUNS_FILE")
  if [ -z "$LAST" ]; then echo "No runs recorded."; exit 0; fi
  JOB=$(echo "$LAST" | jq -r '.jobId // "—"')
  TS=$(echo "$LAST" | jq -r '.completedAt // .startedAt // ""')
  STEPS=$(echo "$LAST" | jq '.steps | length // 0' 2>/dev/null || echo 0)
  COST=$(echo "$LAST" | jq -r '.approxCostUsd // "0"')
  MISER=$(echo "$LAST" | jq -r '.miserLevel // 0')
  STATUS=$(echo "$LAST" | jq -r '.status // "ok"')
  OPUS=$(_tm_opus_est "$COST")
  SAVED=$(awk "BEGIN { printf \"%.4f\", $OPUS - $COST }")
  TIME_AGO=$( [ -n "$TS" ] && _tm_relative_time "$TS" || echo "—")
  echo "Last run: ${JOB} · ${TIME_AGO} · ${STEPS} steps · cost: ~\$${COST} · savings: ~\$${SAVED} vs Opus4"
  echo "Model: $(_tm_infer_model "$MISER")   MISER: ${MISER}   Status: ${STATUS}"
  exit 0
fi

if [ "${MARKERS:-}" = "--cost" ] || [ "${MARKERS:-}" = "--history" ]; then
  if [ ! -f "$RUNS_FILE" ]; then
    echo "No runs found (${RUNS_FILE} missing)."
    exit 0
  fi
  LIMIT=10
  [ "${MARKERS:-}" = "--history" ] && LIMIT=9999
  printf "%-28s %-8s %-12s %-10s %-10s %s\n" "Run" "Model" "Tokens" "Cost" "Opus4 est" "Saved"
  printf "%-28s %-8s %-12s %-10s %-10s %s\n" "---" "-----" "------" "----" "---------" "-----"
  # Read newest-first (tail -r on macOS, tac on Linux)
  (_TM_REV_CMD="tail -r"; command -v tac &>/dev/null && _TM_REV_CMD="tac"; eval "$_TM_REV_CMD \"$RUNS_FILE\"") 2>/dev/null | head -n "$LIMIT" | while IFS= read -r LINE; do
    [ -z "$LINE" ] && continue
    JOB=$(echo "$LINE" | jq -r '.jobId // "—"' | cut -c1-24)
    MISER=$(echo "$LINE" | jq -r '.miserLevel // 0')
    MODEL=$(_tm_infer_model "$MISER")
    INP=$(echo "$LINE" | jq -r '.tokenUsage.inputTokens // 0')
    OUT=$(echo "$LINE" | jq -r '.tokenUsage.outputTokens // 0')
    TOK=$(awk "BEGIN { i=$INP; o=$OUT; if(i+o>0){ if(i>1000) printf \"%dk\",i/1000; else printf \"%d\",i; printf \"/%d\",o } else print \"—\" }")
    COST=$(echo "$LINE" | jq -r '.approxCostUsd // "0"')
    OPUS=$(_tm_opus_est "$COST")
    PCT=$(_tm_savings_pct "$COST" "$OPUS")
    printf "%-28s %-8s %-12s \$%-9s \$%-9s %s%%\n" "$JOB" "$MODEL" "$TOK" "$COST" "$OPUS" "$PCT"
  done
  exit 0
fi

if [ "${MARKERS:-}" = "--export" ]; then
  if [ ! -f "$RUNS_FILE" ]; then
    echo "No runs found (${RUNS_FILE} missing)."
    exit 0
  fi
  RUNS_DATA=$(cat "$RUNS_FILE")
  OUT_FILE="dashboard.html"
  cat > "$OUT_FILE" <<HTMLEOF
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>Tokenmiser Dashboard Export</title>
<style>
  body { font-family: 'SFMono-Regular', Consolas, monospace; background: #0f172a; color: #e2e8f0; margin: 0; padding: 2rem; }
  h1 { font-size: 1.25rem; color: #e2e8f0; margin-bottom: 1rem; }
  table { width: 100%; border-collapse: collapse; font-size: 0.8125rem; }
  th { background: #1e293b; padding: 0.5rem 0.75rem; text-align: left; color: #94a3b8; font-size: 0.6875rem; text-transform: uppercase; letter-spacing: 0.06em; }
  td { padding: 0.5rem 0.75rem; border-bottom: 1px solid #334155; }
  tr:hover td { background: rgba(255,255,255,0.025); }
  .ok { color: #6ee7b7; } .fail { color: #fca5a5; } .esc { color: #fcd34d; }
  .muted { color: #94a3b8; } .green { color: #059669; } .blue { color: #0070f3; }
  footer { margin-top: 1.5rem; color: #475569; font-size: 0.75rem; }
</style>
</head>
<body>
<h1>Tokenmiser Runs — Exported $(date)</h1>
<div id="app">Loading…</div>
<script>
const raw = \`${RUNS_DATA}\`;
const runs = raw.trim().split('\n').map(l => { try { return JSON.parse(l); } catch { return null; } }).filter(Boolean);
function rel(ts) {
  if (!ts) return '—';
  const d = (Date.now() - new Date(ts)) / 1000;
  if (d < 120) return 'just now';
  if (d < 3600) return Math.floor(d/60) + ' min ago';
  if (d < 86400) return Math.floor(d/3600) + ' hr ago';
  return Math.floor(d/86400) + ' days ago';
}
function opusCost(r) {
  if (r.tokenUsage) return (r.tokenUsage.inputTokens||0)/1e6*15 + (r.tokenUsage.outputTokens||0)/1e6*75;
  return parseFloat(r.approxCostUsd||0) * 5;
}
function model(r) {
  const m = parseInt(r.miserLevel||0);
  return m >= 8 ? 'haiku' : 'sonnet';
}
function badge(s) {
  if (s === 'escalated') return '<span class="esc">⚡</span>';
  if (s === 'failed' || s === 'error') return '<span class="fail">✗</span>';
  return '<span class="ok">✓</span>';
}
let html = '<table><thead><tr><th>#</th><th>Time</th><th>Job</th><th>Model</th><th>Cost</th><th>Opus4 Est</th><th>Saved</th><th>Status</th></tr></thead><tbody>';
[...runs].reverse().forEach((r, i) => {
  const cost = parseFloat(r.approxCostUsd||0);
  const opus = opusCost(r);
  const saved = opus - cost;
  const pct = opus > 0 ? Math.round(saved/opus*100) : 0;
  html += \`<tr>
    <td class="muted">\${runs.length - i}</td>
    <td class="muted">\${rel(r.timestamp)}</td>
    <td>\${(r.jobId||'—').substring(0,28)}</td>
    <td class="blue">\${model(r)}</td>
    <td>\$\${cost.toFixed(4)}</td>
    <td class="muted">\$\${opus.toFixed(4)}</td>
    <td class="green">\$\${saved.toFixed(4)} (\${pct}%)</td>
    <td>\${badge(r.status)}</td>
  </tr>\`;
});
html += '</tbody></table>';
document.getElementById('app').innerHTML = html;
</script>
<footer>Powered by Tokenmiser v2 · Generated $(date)</footer>
</body>
</html>
HTMLEOF
  echo "✅ Exported to ${OUT_FILE}"
  open "$OUT_FILE" 2>/dev/null || true
  exit 0
fi

PLAN_FILE="PLAN.md"

if [ ! -f "$PLAN_FILE" ]; then
  echo "❌ tokenmiser: no PLAN.md found in $(pwd)" >&2
  exit 1
fi

PLAN=$(cat "$PLAN_FILE")
PLAN_LINES=$(wc -l < "$PLAN_FILE")

# Extract MISER level
MISER_LEVEL=0
if echo "$MARKERS" | grep -qE '\[MISER=([0-9]+)\]'; then
  MISER_LEVEL=$(echo "$MARKERS" | grep -oE '\[MISER=([0-9]+)\]' | grep -oE '[0-9]+')
fi

# Extract special markers
DEPLOY=0
VALIDATE_CMD=""
YOLO=0

if echo "$MARKERS" | grep -q '\[DEPLOY\]'; then
  DEPLOY=1
fi
if echo "$MARKERS" | grep -qE '\[VALIDATE=([^]]+)\]'; then
  VALIDATE_CMD=$(echo "$MARKERS" | grep -oE '\[VALIDATE=([^]]+)\]' | sed 's/\[VALIDATE=//;s/\]//')
elif echo "$MARKERS" | grep -q '\[VALIDATE\]'; then
  VALIDATE_CMD="npx playwright test"
fi
if echo "$MARKERS" | grep -q '\[YOLO\]'; then
  YOLO=1
fi

AUTO_APPROVE=0
if echo "$MARKERS" | grep -q '\[AUTO_APPROVE\]'; then
  AUTO_APPROVE=1
fi

TDD_MODE=0
if echo "$MARKERS" | grep -q '\[TDD\]'; then
  TDD_MODE=1
fi

# Tool-routing overrides — default "auto" means let MISER/decompose decide
TM_TESTS_WITH="auto"
TM_PLAN_WITH="auto"
TM_CODE_WITH="auto"
if echo "$MARKERS" | grep -qE '\[TESTS_WITH=[^]]+\]'; then
  TM_TESTS_WITH=$(echo "$MARKERS" | grep -oE '\[TESTS_WITH=[^]]+\]' | sed 's/\[TESTS_WITH=//;s/\]//' | tr '[:upper:]' '[:lower:]')
fi
if echo "$MARKERS" | grep -qE '\[PLAN_WITH=[^]]+\]'; then
  TM_PLAN_WITH=$(echo "$MARKERS" | grep -oE '\[PLAN_WITH=[^]]+\]' | sed 's/\[PLAN_WITH=//;s/\]//' | tr '[:upper:]' '[:lower:]')
fi
if echo "$MARKERS" | grep -qE '\[CODE_WITH=[^]]+\]'; then
  TM_CODE_WITH=$(echo "$MARKERS" | grep -oE '\[CODE_WITH=[^]]+\]' | sed 's/\[CODE_WITH=//;s/\]//' | tr '[:upper:]' '[:lower:]')
fi
export TM_TESTS_WITH TM_PLAN_WITH TM_CODE_WITH

# Disable codex when rate-limited or explicitly requested
DISABLE_CODEX=false
if echo "$MARKERS" | grep -q '\[DISABLE_CODEX\]'; then
  DISABLE_CODEX=true
fi
export DISABLE_CODEX

# YOLO implies auto-approve
if [ "$YOLO" -eq 1 ]; then
  AUTO_APPROVE=1
fi

LINEAR=0
REACTIVE=0
if echo "$MARKERS" | grep -q '\[LINEAR\]'; then
  LINEAR=1
fi
if echo "$MARKERS" | grep -q '\[REACTIVE\]'; then
  REACTIVE=1
fi

# Build MISER 11 note if applicable
MISER11_NOTE=""
if echo "$MARKERS" | grep -q '\[MISER=11\]'; then
  MISER11_NOTE="MISER=11 means never use Opus or Sonnet — plan for Haiku/Codex/FJ only."
fi

# Build YOLO note
YOLO_NOTE=""
if [ "$YOLO" -eq 1 ]; then
  YOLO_NOTE="Skip screenshots and video steps."
fi

# Build mode note
MODE_NOTE=""
if [ "$LINEAR" -eq 1 ]; then
  MODE_NOTE="EXECUTION MODE: LINEAR. Before writing any code, output a complete annotated step list showing which tool/model handles each step. Then execute all steps in order."
elif [ "$REACTIVE" -eq 1 ]; then
  MODE_NOTE="EXECUTION MODE: REACTIVE. Default to the cheapest approach (bash edits, no LLM calls where possible). Only escalate to a more capable model if a step fails or is genuinely ambiguous. Prefer local tools first."
fi

# ── route_task: recommend model tier based on PLAN.md and MISER level ──────────
route_task() {
  local tier="sonnet"
  local reason="default"

  if [ "$MISER_LEVEL" -eq 11 ]; then
    tier="haiku"; reason="MISER=11"
  elif [ "$MISER_LEVEL" -ge 8 ]; then
    tier="haiku"; reason="MISER>=8"
  elif echo "$PLAN" | grep -qE '\b(DECISION|DESIGN|ARCHITECTURE|BLOCKED)\b'; then
    tier="sonnet"; reason="plan contains DECISION/DESIGN/ARCHITECTURE/BLOCKED"
  elif [ "$PLAN_LINES" -gt 60 ]; then
    tier="sonnet"; reason="plan > 60 lines"
  elif [ "$MISER_LEVEL" -ge 5 ]; then
    tier="haiku"; reason="MISER>=5"
  fi

  echo "$tier|$reason"
}

ROUTE=$(route_task)
ROUTE_TIER="${ROUTE%|*}"
ROUTE_REASON="${ROUTE#*|}"
echo "🔀 routing: $ROUTE_TIER (reason: $ROUTE_REASON)"

# ── Decompose PLAN.md into JobSpec if we have the TypeScript executor ─────────
USE_EXECUTOR=0
if command -v npx &>/dev/null && [ -f "tools/decompose.ts" ]; then
  USE_EXECUTOR=1
fi

if [ "$USE_EXECUTOR" -eq 1 ]; then
  echo ""
  echo "🔬 Decomposing PLAN.md into job spec (haiku)..."
  if MISER_LEVEL="$MISER_LEVEL" MARKERS="$MARKERS" npx --yes tsx tools/decompose.ts "$PLAN_FILE" 2>&1; then
    echo ""
    echo "📋 Job phases:"
    if command -v jq &>/dev/null && [ -f ".claude/job.json" ]; then
      jq -r '.phases[] | "  \(if .parallel then "⚡" else "→" end) \(.name): \(.steps | length) steps [\([.steps[].tool] | unique | join("+")] | join(""))]"' .claude/job.json 2>/dev/null || true
    fi
    echo ""

    # ── TDD: generate failing specs (red phase) ───────────────────────────────
    TDD_SPECS=""
    if [ "$TDD_MODE" -eq 1 ] && [ -f "tools/gen-tests.ts" ]; then
      echo "🧪 [TDD] Extracting new block names from job spec..."
      # Extract unique block names referenced in step args (paths like blocks/<name>)
      BLOCK_NAMES=$(node -e "
        try {
          const j = JSON.parse(require('fs').readFileSync('.claude/job.json','utf8'));
          const names = new Set();
          j.phases.forEach(p => (p.steps||[]).forEach(s => {
            const text = JSON.stringify(s.args||{});
            for (const m of text.matchAll(/blocks\\/([a-z0-9-]+)/g)) names.add(m[1]);
          }));
          console.log([...names].join('\n'));
        } catch(e) { /* no job.json yet */ }
      " 2>/dev/null || true)

      if [ -n "$BLOCK_NAMES" ]; then
        while IFS= read -r BLOCK; do
          [ -z "$BLOCK" ] && continue
          echo "🧪 [TDD] Generating spec for: $BLOCK"
          # Use || true so a non-zero exit from gen-tests never kills the parent (set -e safe)
          SPEC_PATH=$(npx --yes tsx tools/gen-tests.ts "$BLOCK" "$PLAN_FILE" 2>&1 || true)
          # The actual path is always printed as the last non-empty line
          SPEC_PATH=$(echo "$SPEC_PATH" | grep -E '^tests/' | tail -1 || true)
          if [ -n "$SPEC_PATH" ] && [ -f "$SPEC_PATH" ]; then
            TDD_SPECS="${TDD_SPECS:+$TDD_SPECS }$SPEC_PATH"
            echo "   ✅ spec: $SPEC_PATH"
          else
            echo "   ⚠️  spec generation failed for $BLOCK — skipping"
          fi
        done <<< "$BLOCK_NAMES"
      fi

      # Only attempt playwright if dev server is already up — don't block the build
      TM_SERVER_UP=0
      if curl -sf --max-time 2 http://localhost:3000 > /dev/null 2>&1; then
        TM_SERVER_UP=1
      fi

      if [ -n "$TDD_SPECS" ] && [ "$TM_SERVER_UP" -eq 1 ]; then
        echo ""
        echo "🔴 [TDD] Verifying tests fail before build (red phase)..."
        # shellcheck disable=SC2086
        if npx playwright test $TDD_SPECS --reporter=list 2>&1; then
          echo "⚠️  [TDD] Tests PASSED before building — specs may not be testing the right things."
          echo "   Continuing anyway."
        else
          echo "✅ [TDD] Tests correctly failed (red). Proceeding with build..."
        fi
        echo ""
      elif [ -n "$TDD_SPECS" ]; then
        echo "⚠️  [TDD] Dev server not running — skipping red-phase check. Specs written; green check after build."
        echo ""
      fi
    fi

    echo "⚙️  Executing job spec..."
    mkdir -p .tokenmiser tokenmiser-data .claude
    # Signal to executor that MCP bridge is available (this session can fulfill fj.mcp requests)
    touch .claude/mcp-bridge.active
    export MISER_LEVEL
    JOB_ID="$(date +%Y%m%d_%H%M%S)_$(head -3 "$PLAN_FILE" | tail -1 | tr ' ' '_' | tr -dc '[:alnum:]_' | cut -c1-24)"
    RUN_START="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    RUN_DESC="$(grep -m1 '^[^#]' "$PLAN_FILE" | head -c 80 | sed 's/"/\\"/g')"
    printf '%s\n' "{\"jobId\":\"${JOB_ID}\",\"startedAt\":\"${RUN_START}\",\"miserLevel\":${MISER_LEVEL},\"modelTier\":\"${ROUTE_TIER}\",\"status\":\"running\",\"description\":\"${RUN_DESC}\"}" >> .tokenmiser/runs.json
    # Sync immediately so the dashboard shows the live running job
    cp .tokenmiser/runs.json tokenmiser-data/runs.json 2>/dev/null || true
    TMPOUT=$(mktemp)
    MISER_LEVEL="$MISER_LEVEL" npx --yes tsx tools/code-executor.ts 2>&1 | tee "$TMPOUT"
    EXECUTOR_EXIT=${PIPESTATUS[0]}
    RUN_END="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    EXEC_STATUS="ok"
    [ "$EXECUTOR_EXIT" -ne 0 ] && EXEC_STATUS="failed"
    # Update the specific "running" record for this JOB_ID (not just the last line —
    # the executor also appends its own detailed record, making tail -1 wrong)
    if command -v jq &>/dev/null && [ -f ".tokenmiser/runs.json" ]; then
      TMPFILE=$(mktemp)
      while IFS= read -r _line; do
        _lid=$(echo "$_line" | jq -r '.jobId // ""' 2>/dev/null)
        _lst=$(echo "$_line" | jq -r '.status // ""' 2>/dev/null)
        if [ "$_lid" = "$JOB_ID" ] && [ "$_lst" = "running" ]; then
          echo "$_line" | jq --arg end "$RUN_END" --arg s "$EXEC_STATUS" \
            '. + {completedAt: $end, status: $s}' 2>/dev/null || echo "$_line"
        else
          echo "$_line"
        fi
      done < ".tokenmiser/runs.json" > "$TMPFILE"
      mv "$TMPFILE" .tokenmiser/runs.json
    fi
    cp .tokenmiser/runs.json tokenmiser-data/runs.json 2>/dev/null || true
    rm -f "$TMPOUT" .claude/mcp-bridge.active

    # ── TDD: verify green + promote to critical path ──────────────────────────
    # Re-check server in case it came up during the build
    if curl -sf --max-time 2 http://localhost:3000 > /dev/null 2>&1; then
      TM_SERVER_UP=1
    fi
    if [ "$TDD_MODE" -eq 1 ] && [ -n "$TDD_SPECS" ] && [ "$TM_SERVER_UP" -eq 1 ]; then
      echo ""
      echo "🟢 [TDD] Verifying tests pass after build (green phase)..."
      # shellcheck disable=SC2086
      if npx playwright test $TDD_SPECS --reporter=list 2>&1; then
        echo ""
        echo "✅ [TDD] Tests passed! Promoting to critical path..."
        node -e "
          const fs = require('fs');
          const cpFile = 'tests/critical-path.json';
          const existing = fs.existsSync(cpFile)
            ? JSON.parse(fs.readFileSync(cpFile, 'utf8'))
            : [];
          const toAdd = '${TDD_SPECS}'.trim().split(/\s+/).filter(Boolean);
          const updated = [...new Set([...existing, ...toAdd])];
          fs.writeFileSync(cpFile, JSON.stringify(updated, null, 2) + '\n');
          toAdd.forEach(s => console.log('  ✅ promoted:', s));
        " 2>&1
      else
        echo ""
        echo "❌ [TDD] Tests FAILED after build. Review the implementation."
        echo "   Specs written to: $TDD_SPECS"
        echo "   NOT promoted to critical path — fix failures first."
      fi
    elif [ "$TDD_MODE" -eq 1 ] && [ -n "$TDD_SPECS" ]; then
      echo ""
      echo "⚠️  [TDD] Dev server not running — skipping green-phase check."
      echo "   Run manually: npx playwright test $TDD_SPECS"
      echo "   Then promote passing specs: node -e \"const fs=require('fs'); const f='tests/critical-path.json'; const e=JSON.parse(fs.readFileSync(f)); fs.writeFileSync(f,JSON.stringify([...new Set([...e,...'${TDD_SPECS}'.split(' ')])],null,2)+'\\n')\""
    fi

    # Skip the rest of the tokenmiser claude -p flow
    echo ""
    echo "✅ Executor pipeline complete."
    exit 0
  else
    echo "⚠️  Decompose failed, falling back to claude -p"
  fi
fi

# Select model flag
MODEL_FLAG=""
if [ "$ROUTE_TIER" = "haiku" ]; then
  MODEL_FLAG="--model claude-haiku-4-5-20251001"
fi

# Permission mode: explicit --auto-approve flag, otherwise default (prompts for risky ops)
PERM_MODE="default"
if [ "$AUTO_APPROVE" -eq 1 ]; then
  PERM_MODE="acceptEdits"
fi

# Build prompt: markers + PLAN.md content + codebase hints
PROMPT=$(cat <<PROMPT
${MARKERS:+$MARKERS

}${MISER11_NOTE:+$MISER11_NOTE
}${YOLO_NOTE:+$YOLO_NOTE
}${MODE_NOTE:+$MODE_NOTE
}You are an expert AEM Edge Delivery Services engineer working in this repository.
Read the following PLAN.md and execute it completely.

Approach:
- Use bash tools to read existing files before writing new ones.
- Prefer targeted patch-style edits over full-file rewrites.
- Run local fixers (npx eslint --fix, npx stylelint --fix) after writing code.
- Run npm run build:json after touching any block model JSON.
- Run npx playwright test for any specified test files.
- Write a concise summary of what you did at the end.
- When adding new EDS blocks, always add them to models/_section.json filters and re-run build:json.

PLAN.md:
---
${PLAN}
---
PROMPT
)

echo "🚀 tokenmiser: dispatching to claude -p (markers: ${MARKERS:-none})"
echo "   Plan: $(head -3 "$PLAN_FILE" | tail -1)"
echo ""

# ── Write initial run record before dispatch ─────────────────────────────────
mkdir -p .tokenmiser tokenmiser-data
JOB_ID="$(date +%Y%m%d_%H%M%S)_$(head -3 "$PLAN_FILE" | tail -1 | tr ' ' '_' | tr -dc '[:alnum:]_' | cut -c1-24)"
RUN_START="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
RUN_DESC="$(grep -m1 '^[^#]' "$PLAN_FILE" | head -c 80 | sed 's/"/\\"/g')"
printf '%s\n' "{\"jobId\":\"${JOB_ID}\",\"startedAt\":\"${RUN_START}\",\"miserLevel\":${MISER_LEVEL},\"modelTier\":\"${ROUTE_TIER}\",\"status\":\"running\",\"description\":\"${RUN_DESC}\"}" >> .tokenmiser/runs.json
# Sync immediately so the dashboard live bar shows the running job
cp .tokenmiser/runs.json tokenmiser-data/runs.json 2>/dev/null || true

# Capture output to temp file for token extraction
TMPOUT=$(mktemp)
# shellcheck disable=SC2086
echo "$PROMPT" | claude -p --permission-mode "$PERM_MODE" \
  --output-format stream-json --verbose $MODEL_FLAG 2>&1 | tee "$TMPOUT"

# ── Token usage summary ──────────────────────────────────────────────────────
if command -v jq &>/dev/null; then
  # Extract modelUsage from the stream-json output (last occurrence)
  INPUT_TOKENS=$(grep '"modelUsage"' "$TMPOUT" | tail -1 | jq -r '.modelUsage.inputTokens // 0' 2>/dev/null || echo 0)
  OUTPUT_TOKENS=$(grep '"modelUsage"' "$TMPOUT" | tail -1 | jq -r '.modelUsage.outputTokens // 0' 2>/dev/null || echo 0)
  CACHE_READ=$(grep '"modelUsage"' "$TMPOUT" | tail -1 | jq -r '.modelUsage.cacheReadTokens // 0' 2>/dev/null || echo 0)
  CACHE_WRITE=$(grep '"modelUsage"' "$TMPOUT" | tail -1 | jq -r '.modelUsage.cacheWriteTokens // 0' 2>/dev/null || echo 0)

  if [ "$INPUT_TOKENS" -gt 0 ] || [ "$OUTPUT_TOKENS" -gt 0 ]; then
    GROUNDTRUTH=~/bin/groundtruth
    if [ -x "$GROUNDTRUTH" ]; then
      COST_IN=$("$GROUNDTRUTH" math eval "3 * $INPUT_TOKENS / 1000000" 2>/dev/null || echo "?")
      COST_OUT=$("$GROUNDTRUTH" math eval "15 * $OUTPUT_TOKENS / 1000000" 2>/dev/null || echo "?")
      COST_CR=$("$GROUNDTRUTH" math eval "0.30 * $CACHE_READ / 1000000" 2>/dev/null || echo "0")
      COST_CW=$("$GROUNDTRUTH" math eval "3.75 * $CACHE_WRITE / 1000000" 2>/dev/null || echo "0")
      TOTAL_COST=$("$GROUNDTRUTH" math eval "$COST_IN + $COST_OUT + $COST_CR + $COST_CW" 2>/dev/null || echo "?")
    else
      TOTAL_COST="?"
    fi

    echo ""
    echo "💰 tokens: ${INPUT_TOKENS}in ${OUTPUT_TOKENS}out  cost: ~\$$TOTAL_COST"

    if [ "$INPUT_TOKENS" -gt 160000 ]; then
      echo "⚠ large context ($(( INPUT_TOKENS / 1000 ))k tokens)"
    fi

    # Merge cost summary into last line of .tokenmiser/runs.json
    RUNS_FILE=".tokenmiser/runs.json"
    if [ -f "$RUNS_FILE" ] && command -v jq &>/dev/null; then
      LAST_LINE=$(tail -1 "$RUNS_FILE")
      if [ -n "$LAST_LINE" ]; then
        RUN_END="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
        UPDATED=$(echo "$LAST_LINE" | jq \
          --argjson inp "$INPUT_TOKENS" \
          --argjson out "$OUTPUT_TOKENS" \
          --arg cost "$TOTAL_COST" \
          --arg end "$RUN_END" \
          '. + {tokenUsage: {inputTokens: $inp, outputTokens: $out}, approxCostUsd: $cost, completedAt: $end, status: "ok"}' 2>/dev/null || echo "")
        if [ -n "$UPDATED" ]; then
          # Replace last line
          TMPFILE=$(mktemp)
          head -n -1 "$RUNS_FILE" > "$TMPFILE"
          echo "$UPDATED" >> "$TMPFILE"
          mv "$TMPFILE" "$RUNS_FILE"
        fi
      fi
    fi
  fi
fi
rm -f "$TMPOUT"
cp .tokenmiser/runs.json tokenmiser-data/runs.json 2>/dev/null || true

# Post-completion: deploy if requested
if [ "$DEPLOY" -eq 1 ]; then
  echo ""
  echo "🚀 [DEPLOY] Committing and pushing changes..."
  git add -A
  git commit -m "chore: tokenmiser auto-deploy"
  git push
  PUSHED_BRANCH=$(git rev-parse --abbrev-ref HEAD)
  PUSHED_COMMIT=$(git rev-parse --short HEAD)
  echo "✅ [DEPLOY] Pushed branch '$PUSHED_BRANCH' at commit $PUSHED_COMMIT"

  # Validate if requested
  if [ -n "$VALIDATE_CMD" ]; then
    echo ""
    echo "🧪 [VALIDATE] Running: $VALIDATE_CMD"
    if eval "$VALIDATE_CMD"; then
      echo "✅ [VALIDATE] Passed: $VALIDATE_CMD"
    else
      echo "❌ [VALIDATE] Failed: $VALIDATE_CMD" >&2
      exit 1
    fi
  fi
fi
