#!/usr/bin/env bash
# tokenmiser — reads PLAN.md + markers, dispatches to claude -p
# Called by `t` when present in the repo root.
# Usage: ./tokenmiser "[PATCH] [MISER=N] [LINEAR] [REACTIVE] [DEPLOY] [VALIDATE=cmd] [YOLO] optional task override"
set -euo pipefail

MARKERS="${1:-}"
PLAN_FILE="PLAN.md"

if [ ! -f "$PLAN_FILE" ]; then
  echo "❌ tokenmiser: no PLAN.md found in $(pwd)" >&2
  exit 1
fi

PLAN=$(cat "$PLAN_FILE")
PLAN_LINES=$(wc -l < "$PLAN_FILE")

# Extract MISER level
MISER_LEVEL=0
if echo "$MARKERS" | grep -qE '\[MISER=([0-9]+)\]'; then
  MISER_LEVEL=$(echo "$MARKERS" | grep -oE '\[MISER=([0-9]+)\]' | grep -oE '[0-9]+')
fi

# Extract special markers
DEPLOY=0
VALIDATE_CMD=""
YOLO=0

if echo "$MARKERS" | grep -q '\[DEPLOY\]'; then
  DEPLOY=1
fi
if echo "$MARKERS" | grep -qE '\[VALIDATE=([^]]+)\]'; then
  VALIDATE_CMD=$(echo "$MARKERS" | grep -oE '\[VALIDATE=([^]]+)\]' | sed 's/\[VALIDATE=//;s/\]//')
elif echo "$MARKERS" | grep -q '\[VALIDATE\]'; then
  VALIDATE_CMD="npx playwright test"
fi
if echo "$MARKERS" | grep -q '\[YOLO\]'; then
  YOLO=1
fi

AUTO_APPROVE=0
if echo "$MARKERS" | grep -q '\[AUTO_APPROVE\]'; then
  AUTO_APPROVE=1
fi
# YOLO implies auto-approve
if [ "$YOLO" -eq 1 ]; then
  AUTO_APPROVE=1
fi

LINEAR=0
REACTIVE=0
if echo "$MARKERS" | grep -q '\[LINEAR\]'; then
  LINEAR=1
fi
if echo "$MARKERS" | grep -q '\[REACTIVE\]'; then
  REACTIVE=1
fi

# Build MISER 11 note if applicable
MISER11_NOTE=""
if echo "$MARKERS" | grep -q '\[MISER=11\]'; then
  MISER11_NOTE="MISER=11 means never use Opus or Sonnet — plan for Haiku/Codex/FJ only."
fi

# Build YOLO note
YOLO_NOTE=""
if [ "$YOLO" -eq 1 ]; then
  YOLO_NOTE="Skip screenshots and video steps."
fi

# Build mode note
MODE_NOTE=""
if [ "$LINEAR" -eq 1 ]; then
  MODE_NOTE="EXECUTION MODE: LINEAR. Before writing any code, output a complete annotated step list showing which tool/model handles each step. Then execute all steps in order."
elif [ "$REACTIVE" -eq 1 ]; then
  MODE_NOTE="EXECUTION MODE: REACTIVE. Default to the cheapest approach (bash edits, no LLM calls where possible). Only escalate to a more capable model if a step fails or is genuinely ambiguous. Prefer local tools first."
fi

# ── route_task: recommend model tier based on PLAN.md and MISER level ──────────
route_task() {
  local tier="sonnet"
  local reason="default"

  if [ "$MISER_LEVEL" -eq 11 ]; then
    tier="haiku"; reason="MISER=11"
  elif [ "$MISER_LEVEL" -ge 8 ]; then
    tier="haiku"; reason="MISER>=8"
  elif echo "$PLAN" | grep -qE '\b(DECISION|DESIGN|ARCHITECTURE|BLOCKED)\b'; then
    tier="sonnet"; reason="plan contains DECISION/DESIGN/ARCHITECTURE/BLOCKED"
  elif [ "$PLAN_LINES" -gt 60 ]; then
    tier="sonnet"; reason="plan > 60 lines"
  elif [ "$MISER_LEVEL" -ge 5 ]; then
    tier="haiku"; reason="MISER>=5"
  fi

  echo "$tier|$reason"
}

ROUTE=$(route_task)
ROUTE_TIER="${ROUTE%|*}"
ROUTE_REASON="${ROUTE#*|}"
echo "🔀 routing: $ROUTE_TIER (reason: $ROUTE_REASON)"

# Select model flag
MODEL_FLAG=""
if [ "$ROUTE_TIER" = "haiku" ]; then
  MODEL_FLAG="--model claude-haiku-4-5-20251001"
fi

# Permission mode: explicit --auto-approve flag, otherwise default (prompts for risky ops)
PERM_MODE="default"
if [ "$AUTO_APPROVE" -eq 1 ]; then
  PERM_MODE="acceptEdits"
fi

# Build prompt: markers + PLAN.md content + codebase hints
PROMPT=$(cat <<PROMPT
${MARKERS:+$MARKERS

}${MISER11_NOTE:+$MISER11_NOTE
}${YOLO_NOTE:+$YOLO_NOTE
}${MODE_NOTE:+$MODE_NOTE
}You are an expert AEM Edge Delivery Services engineer working in this repository.
Read the following PLAN.md and execute it completely.

Approach:
- Use bash tools to read existing files before writing new ones.
- Prefer targeted patch-style edits over full-file rewrites.
- Run local fixers (npx eslint --fix, npx stylelint --fix) after writing code.
- Run npm run build:json after touching any block model JSON.
- Run npx playwright test for any specified test files.
- Write a concise summary of what you did at the end.
- When adding new EDS blocks, always add them to models/_section.json filters and re-run build:json.

PLAN.md:
---
${PLAN}
---
PROMPT
)

echo "🚀 tokenmiser: dispatching to claude -p (markers: ${MARKERS:-none})"
echo "   Plan: $(head -3 "$PLAN_FILE" | tail -1)"
echo ""

# Capture output to temp file for token extraction
TMPOUT=$(mktemp)
# shellcheck disable=SC2086
echo "$PROMPT" | claude -p --permission-mode "$PERM_MODE" \
  --output-format stream-json --verbose $MODEL_FLAG 2>&1 | tee "$TMPOUT"

# ── Token usage summary ──────────────────────────────────────────────────────
if command -v jq &>/dev/null; then
  # Extract modelUsage from the stream-json output (last occurrence)
  INPUT_TOKENS=$(grep '"modelUsage"' "$TMPOUT" | tail -1 | jq -r '.modelUsage.inputTokens // 0' 2>/dev/null || echo 0)
  OUTPUT_TOKENS=$(grep '"modelUsage"' "$TMPOUT" | tail -1 | jq -r '.modelUsage.outputTokens // 0' 2>/dev/null || echo 0)
  CACHE_READ=$(grep '"modelUsage"' "$TMPOUT" | tail -1 | jq -r '.modelUsage.cacheReadTokens // 0' 2>/dev/null || echo 0)
  CACHE_WRITE=$(grep '"modelUsage"' "$TMPOUT" | tail -1 | jq -r '.modelUsage.cacheWriteTokens // 0' 2>/dev/null || echo 0)

  if [ "$INPUT_TOKENS" -gt 0 ] || [ "$OUTPUT_TOKENS" -gt 0 ]; then
    GROUNDTRUTH=~/bin/groundtruth
    if [ -x "$GROUNDTRUTH" ]; then
      COST_IN=$("$GROUNDTRUTH" math eval "3 * $INPUT_TOKENS / 1000000" 2>/dev/null || echo "?")
      COST_OUT=$("$GROUNDTRUTH" math eval "15 * $OUTPUT_TOKENS / 1000000" 2>/dev/null || echo "?")
      COST_CR=$("$GROUNDTRUTH" math eval "0.30 * $CACHE_READ / 1000000" 2>/dev/null || echo "0")
      COST_CW=$("$GROUNDTRUTH" math eval "3.75 * $CACHE_WRITE / 1000000" 2>/dev/null || echo "0")
      TOTAL_COST=$("$GROUNDTRUTH" math eval "$COST_IN + $COST_OUT + $COST_CR + $COST_CW" 2>/dev/null || echo "?")
    else
      TOTAL_COST="?"
    fi

    echo ""
    echo "💰 tokens: ${INPUT_TOKENS}in ${OUTPUT_TOKENS}out  cost: ~\$$TOTAL_COST"

    if [ "$INPUT_TOKENS" -gt 160000 ]; then
      echo "⚠ large context ($(( INPUT_TOKENS / 1000 ))k tokens)"
    fi

    # Merge cost summary into last line of .tokenmiser/runs.json
    RUNS_FILE=".tokenmiser/runs.json"
    if [ -f "$RUNS_FILE" ] && command -v jq &>/dev/null; then
      LAST_LINE=$(tail -1 "$RUNS_FILE")
      if [ -n "$LAST_LINE" ]; then
        UPDATED=$(echo "$LAST_LINE" | jq \
          --argjson inp "$INPUT_TOKENS" \
          --argjson out "$OUTPUT_TOKENS" \
          --arg cost "$TOTAL_COST" \
          '. + {tokenUsage: {inputTokens: $inp, outputTokens: $out}, approxCostUsd: $cost}' 2>/dev/null || echo "")
        if [ -n "$UPDATED" ]; then
          # Replace last line
          TMPFILE=$(mktemp)
          head -n -1 "$RUNS_FILE" > "$TMPFILE"
          echo "$UPDATED" >> "$TMPFILE"
          mv "$TMPFILE" "$RUNS_FILE"
        fi
      fi
    fi
  fi
fi
rm -f "$TMPOUT"

# Post-completion: deploy if requested
if [ "$DEPLOY" -eq 1 ]; then
  echo ""
  echo "🚀 [DEPLOY] Committing and pushing changes..."
  git add -A
  git commit -m "chore: tokenmiser auto-deploy"
  git push
  PUSHED_BRANCH=$(git rev-parse --abbrev-ref HEAD)
  PUSHED_COMMIT=$(git rev-parse --short HEAD)
  echo "✅ [DEPLOY] Pushed branch '$PUSHED_BRANCH' at commit $PUSHED_COMMIT"

  # Validate if requested
  if [ -n "$VALIDATE_CMD" ]; then
    echo ""
    echo "🧪 [VALIDATE] Running: $VALIDATE_CMD"
    if eval "$VALIDATE_CMD"; then
      echo "✅ [VALIDATE] Passed: $VALIDATE_CMD"
    else
      echo "❌ [VALIDATE] Failed: $VALIDATE_CMD" >&2
      exit 1
    fi
  fi
fi
