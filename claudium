#!/usr/bin/env bash
# claudium — reads PLAN.md + markers, dispatches to claude -p
# Called by `t` when present in the repo root.
# Usage: ./claudium "[PATCH] [MISER=N] optional task override"
set -euo pipefail

MARKERS="${1:-}"
PLAN_FILE="PLAN.md"

if [ ! -f "$PLAN_FILE" ]; then
  echo "❌ claudium: no PLAN.md found in $(pwd)" >&2
  exit 1
fi

PLAN=$(cat "$PLAN_FILE")

# Build prompt: markers + PLAN.md content + codebase hints
PROMPT=$(cat <<PROMPT
${MARKERS:+$MARKERS

}You are an expert AEM Edge Delivery Services engineer working in this repository.
Read the following PLAN.md and execute it completely.

Approach:
- Use bash tools to read existing files before writing new ones.
- Prefer targeted patch-style edits over full-file rewrites.
- Run local fixers (npx eslint --fix, npx stylelint --fix) after writing code.
- Run npm run build:json after touching any block model JSON.
- Run npx playwright test for any specified test files.
- Write a concise summary of what you did at the end.
- When adding new EDS blocks, always add them to models/_section.json filters and re-run build:json.

PLAN.md:
---
${PLAN}
---
PROMPT
)

echo "🚀 claudium: dispatching to claude -p (MISER=${MARKERS})"
echo "   Plan: $(head -3 "$PLAN_FILE" | tail -1)"
echo ""

echo "$PROMPT" | claude -p
